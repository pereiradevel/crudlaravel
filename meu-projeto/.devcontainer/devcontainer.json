{
    "name": "SAE Laravel",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/var/www/html",
    "forwardPorts": [8000, 5173, 8081],
    "portsAttributes": {
        "8000": {
            "label": "Laravel",
            "onAutoForward": "openPreview",
            "protocol": "http"
        },
        "5173": {
            "label": "Vite",
            "protocol": "http"
        },
        "8081": {
            "label": "phpMyAdmin",
            "protocol": "http"
        }
    }
}